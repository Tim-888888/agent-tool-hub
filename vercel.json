{
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/discover",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/skills-sh",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/skills-sh/enrich",
      "schedule": "0 5 * * *"
    }
  ],
  "functions": {
    "src/app/api/discover/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/sync/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/skills-sh/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/skills-sh/activate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/skills-sh/enrich/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/skills-sh/translate/route.ts": {
      "maxDuration": 300
    }
  }
}
