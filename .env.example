# Database
DATABASE_URL="postgresql://user:password@localhost:5432/agenttoolhub"

# GitHub API (optional, for higher rate limits)
GITHUB_TOKEN=""

# Auth.js v5 — GitHub OAuth
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Admin — comma-separated GitHub user IDs
ADMIN_GITHUB_IDS=""
# Same IDs with NEXT_PUBLIC_ prefix for client-side admin check
NEXT_PUBLIC_ADMIN_GITHUB_IDS=""

# 智谱 GLM API (for auto-translation during tool approval)
GLM_API_KEY=""

# Cron secret (optional, secures /api/discover cron endpoint)
CRON_SECRET=""

# Base URL for sitemap/canonical URLs
NEXT_PUBLIC_APP_URL="https://agenttoolhub.com"
