generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ToolType {
  MCP_SERVER
  SKILL
  RULE
}

enum ToolStatus {
  PENDING
  ACTIVE
  FEATURED
  ARCHIVED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tool {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  descriptionZh String?
  type          ToolType
  status        ToolStatus @default(ACTIVE)

  repoUrl       String
  homepageUrl   String?
  npmPackage    String?
  pypiPackage   String?

  stars         Int      @default(0)
  forks         Int      @default(0)
  openIssues    Int      @default(0)
  language      String?
  license       String?
  lastCommitAt  DateTime?
  author        String?
  version       String?

  tags          String[]
  transports    String[]

  isFeatured    Boolean  @default(false)
  featuresZh    String[]
  featuresEn    String[]
  installGuide  Json?
  screenshots   String[]

  avgRating     Float    @default(0)
  ratingCount   Int      @default(0)

  score        Float?    // Weighted ranking score (0-100), per D-05/D-08
  syncedAt     DateTime? // Last successful sync timestamp, per D-15
  npmDownloads Int?      // Weekly npm download count, per D-04

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categories    ToolCategory[]
  platforms     ToolPlatform[]
  reviews       Review[]
  submissions   Submission[]
  tagVotes      ToolTagVote[]
  favorites     Favorite[]

  @@index([type, status])
  @@index([stars])
  @@index([lastCommitAt])
  @@index([isFeatured])
  @@index([name])
  @@index([score])
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameEn      String
  nameZh      String
  icon        String
  descriptionEn String?
  descriptionZh String?
  order       Int      @default(0)
  tools       ToolCategory[]

  @@index([slug])
}

model Platform {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  icon        String
  configKey   String
  tools       ToolPlatform[]

  @@index([slug])
}

model ToolCategory {
  toolId     String
  categoryId String
  tool       Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([toolId, categoryId])
}

model ToolPlatform {
  toolId     String
  platformId String
  tool       Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@id([toolId, platformId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  submissions   Submission[]
  tagVotes      ToolTagVote[]
  favorites     Favorite[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Review {
  id          String   @id @default(cuid())
  toolId      String
  tool        Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating      Int
  content     String?
  platform    String?
  useCase     String?
  createdAt   DateTime @default(now())

  @@unique([userId, toolId])
  @@index([toolId])
  @@index([userId])
}

model Submission {
  id              String           @id @default(cuid())
  toolId          String?
  tool            Tool?            @relation(fields: [toolId], references: [id])
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  repoUrl         String
  submitterName   String?
  submitterEmail  String?
  notes           String?
  suggestedTags   String[]
  status          SubmissionStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  reviewedAt      DateTime?

  @@index([status])
}

model ToolTagVote {
  id        String   @id @default(cuid())
  toolId    String
  tagSlug   String
  userId    String
  createdAt DateTime @default(now())

  tool  Tool  @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([toolId, tagSlug, userId])
  @@index([toolId])
  @@index([toolId, tagSlug])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}
